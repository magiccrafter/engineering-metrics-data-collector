# Database Configuration
DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# Initial Ingestion Date (RFC3339 format, e.g., 2023-01-01T00:00:00Z)
# Used when no previous collector run exists in the database
# If not set, defaults to current date/time
INITIAL_INGESTION_DATE="2023-01-01T00:00:00Z"

# GitLab Configuration
GITLAB_GRAPHQL_ENDPOINT="https://gitlab.com/api/graphql"
GITLAB_REST_ENDPOINT="https://gitlab.com/api/v4"
GITLAB_API_TOKEN="Bearer xxxxxxxxxxx"
GITLAB_FULL_PATH_GROUP_LIST="xxxx/xxxx,yyyy/yyyy"

# Github Configuration
# org_slug is the organisation name in GitHub (e.g., 'your-tech')
# DAY is the date for which to fetch metrics in YYYY-MM-DD format (e.g., '2024-01-01')
GITHUB_API_ENDPOINT="https://api.github.com"
GITHUB_API_TOKEN="Bearer xxxxxxxxxxx"
GITHUB_API_VERSION="2026-03-10"
COPILOT_INITIAL_INGESTION_DATE="2026-01-01T00:00:00Z"
GITHUB_COPILOT_ORG_LIST="bvgroup-tech"
# 0 means try to include today
# 1 means stop at yesterday
# 2 means stop at the day before yesterday
COPILOT_REPORT_LAG_DAYS="1"

# AI Configuration
# For OpenAI: https://api.openai.com/v1
# For Local Ollama (Mac with Docker): http://host.docker.internal:11434/v1
AI_BASE_URL="http://host.docker.internal:11434/v1"
# Model Name (e.g., gpt-4, llama3, mistral)
AI_MODEL="gpt-oss:20b"

# API Key (Sk-..., or 'ollama' for local)
AI_API_KEY="ollama"

# Maximum characters for code changes sent to AI (default: 10000)
AI_MAX_CONTEXT_CHARS=10000

# Merge Request Import Configuration
# If false, skip merge requests that already exist in the database
# If true, always upsert (insert or update) merge requests
UPSERT_MERGE_REQUESTS=false